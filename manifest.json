{
  "manifest_version": 3,
  "name": "Click Faster",
  "version": "0.1.0",
  "description": "모든 웹 동영상에서 화면을 누르거나 클릭해 설정한 배속으로 빠르게 재생합니다.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Click Faster",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
